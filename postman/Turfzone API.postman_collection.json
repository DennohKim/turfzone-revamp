        {
          "name": "Receive Paystack Webhook",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const rawBody = pm.collectionVariables.get(\"webhookPayload\");",
                  "const secretKey = pm.collectionVariables.get(\"paystackSecretKey\");",
                  "",
                  "if (secretKey) {",
                  "    const CryptoJS = require(\"crypto-js\");",
                  "    const signature = CryptoJS.HmacSHA512(rawBody, secretKey).toString(CryptoJS.enc.Hex);",
                  "    pm.collectionVariables.set(\"paystackSignature\", signature);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "x-paystack-signature",
                "value": "{{paystackSignature}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{{webhookPayload}}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/payments/webhook",
              "host": ["{{baseUrl}}"],
              "path": ["api", "payments", "webhook"]
            },
            "description": "Provider-authenticated route. Set paystackSecretKey to generate x-paystack-signature over the exact raw body; no Turfzone bearer token is used."
          },
          "response": []
        },
        {
          "name": "Admin Verify Paystack Webhook",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const rawBody = pm.collectionVariables.get(\"webhookPayload\");",
                  "const secretKey = pm.collectionVariables.get(\"paystackSecretKey\");",
                  "let signature = pm.collectionVariables.get(\"paystackSignature\");",
                  "",
                  "if (secretKey) {",
                  "    const CryptoJS = require(\"crypto-js\");",
                  "    signature = CryptoJS.HmacSHA512(rawBody, secretKey).toString(CryptoJS.enc.Hex);",
                  "    pm.collectionVariables.set(\"paystackSignature\", signature);",
                  "}",
                  "",
                  "pm.collectionVariables.set(",
                  "    \"webhookVerifyBody\",",
                  "    JSON.stringify({ raw_body: rawBody, signature })",
                  ");"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{{webhookVerifyBody}}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/payments/webhook/verify",
              "host": ["{{baseUrl}}"],
              "path": ["api", "payments", "webhook", "verify"]
            },
            "description": "Superuser-only test wrapper. Set paystackSecretKey to the same PAYSTACK_SECRET_KEY used by the server; the pre-request script computes the HMAC-SHA512 signature."
          },
          "response": []
        },
