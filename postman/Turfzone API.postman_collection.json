    {
      "name": "Google OAuth",
      "description": "Google OAuth uses browser redirects, a session cookie, state, and PKCE. Set the Google client credentials on the server and register {{baseUrl}}/oauth/google/callback in Google Cloud. Start login in a browser rather than manually calling the callback.",
      "auth": {
        "type": "noauth"
      },
      "item": [
        {
          "name": "List OAuth Providers",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/oauth/providers",
              "host": ["{{baseUrl}}"],
              "path": ["oauth", "providers"]
            },
            "description": "Lists configured providers. Google appears only when both UMBRAL_OAUTH_GOOGLE_CLIENT_ID and UMBRAL_OAUTH_GOOGLE_CLIENT_SECRET are set."
          },
          "response": []
        },
        {
          "name": "Start Google Login",
          "protocolProfileBehavior": {
            "followRedirects": false
          },
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/oauth/google/login",
              "host": ["{{baseUrl}}"],
              "path": ["oauth", "google", "login"]
            },
            "description": "Browser entry point. Returns a redirect to Google and stores OAuth state plus the PKCE verifier in the Umbral session. Open this URL in a browser to complete sign-in."
          },
          "response": []
        },
        {
          "name": "Connect Google Account",
          "protocolProfileBehavior": {
            "followRedirects": false
          },
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/oauth/google/connect",
              "host": ["{{baseUrl}}"],
              "path": ["oauth", "google", "connect"]
            },
            "description": "Connects Google to an existing user. Requires an authenticated Umbral cookie session; bearer authentication alone is not sufficient for this browser flow."
          },
          "response": []
        },
        {
          "name": "Google Callback Template",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/oauth/google/callback?code={{oauthCode}}&state={{oauthState}}",
              "host": ["{{baseUrl}}"],
              "path": ["oauth", "google", "callback"],
              "query": [
                {
                  "key": "code",
                  "value": "{{oauthCode}}"
                },
                {
                  "key": "state",
                  "value": "{{oauthState}}"
                }
              ]
            },
            "description": "Documentation template only. Google calls this with a short-lived code after login. A manually entered code/state will fail because state and PKCE must match the initiating session."
          },
          "response": []
        },
        {
          "name": "Disconnect Google Account",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/oauth/google/disconnect",
              "host": ["{{baseUrl}}"],
              "path": ["oauth", "google", "disconnect"]
            },
            "description": "Disconnects Google from the authenticated user. Requires the browser session and applicable CSRF protection."
          },
          "response": []
        }
      ]
    },
