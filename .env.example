UMBRAL_DATABASE_URL=postgres://turfzone:turfzone@localhost:5432/turfzone
UMBRAL_BIND_ADDR=127.0.0.1:8000
UMBRAL_SECRET_KEY=replace-me-with-32-random-bytes
UMBRAL_ENVIRONMENT=Dev

UMBRAL_OAUTH_PUBLIC_ORIGIN=http://127.0.0.1:8000
UMBRAL_OAUTH_LOGIN_REDIRECT=/
# Register http://127.0.0.1:8000/oauth/google/callback in Google Cloud.
# UMBRAL_OAUTH_GOOGLE_CLIENT_ID=
# UMBRAL_OAUTH_GOOGLE_CLIENT_SECRET=
# Generate this keypair with: cargo run -- maskkeygen
# UMBRAL_MASK_PUBLIC_KEY=
# UMBRAL_MASK_PRIVATE_KEY=

# Auth email delivery. Verify the sender domain in Resend before production.
# RESEND_API_KEY=re_replace_me
# RESEND_FROM_EMAIL=Turfzone <no-reply@your-verified-domain.example>
# RESEND_REPLY_TO=support@your-verified-domain.example

TURFZONE_DEFAULT_CURRENCY=KES
TURFZONE_HOLD_MINUTES=7
TURFZONE_DEFAULT_CANCELLATION_CUTOFF_HOURS=6
TURFZONE_MIN_CANCELLATION_CUTOFF_HOURS=2
TURFZONE_MAX_CANCELLATION_CUTOFF_HOURS=24
TURFZONE_PLATFORM_COMMISSION_BPS=1000
PAYSTACK_SECRET_KEY=sk_test_replace_me
